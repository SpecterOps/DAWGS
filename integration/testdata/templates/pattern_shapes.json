{
  "families": [
    {
      "name": "typed path pattern materialization",
      "template": "match p={{pattern}} where {{predicate}} return p",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"name": "src"}},
          {"id": "b", "kinds": ["NodeKind2"], "properties": {"name": "mid"}},
          {"id": "c", "kinds": ["NodeKind1"], "properties": {"name": "dst"}},
          {"id": "d", "kinds": ["NodeKind2"], "properties": {"name": "inbound-src"}},
          {"id": "e", "kinds": ["NodeKind1"], "properties": {"name": "inbound"}}
        ],
        "edges": [
          {"start_id": "a", "end_id": "b", "kind": "EdgeKind1"},
          {"start_id": "b", "end_id": "c", "kind": "EdgeKind2"},
          {"start_id": "d", "end_id": "e", "kind": "EdgeKind1"}
        ]
      },
      "variants": [
        {
          "name": "directed typed one-hop",
          "vars": {
            "pattern": "(a:NodeKind1)-[:EdgeKind1]->(b:NodeKind2)",
            "predicate": "a.name = 'src'"
          },
          "assert": {"path_node_ids": [["a", "b"]], "path_edge_kinds": [["EdgeKind1"]]}
        },
        {
          "name": "directed typed two-hop",
          "vars": {
            "pattern": "(a:NodeKind1)-[:EdgeKind1]->(b:NodeKind2)-[:EdgeKind2]->(c:NodeKind1)",
            "predicate": "a.name = 'src'"
          },
          "assert": {"path_node_ids": [["a", "b", "c"]], "path_edge_kinds": [["EdgeKind1", "EdgeKind2"]]}
        },
        {
          "name": "inbound typed one-hop",
          "vars": {
            "pattern": "(e:NodeKind1)<-[:EdgeKind1]-(d:NodeKind2)",
            "predicate": "e.name = 'inbound'"
          },
          "assert": {"path_node_ids": [["e", "d"]], "path_edge_kinds": [["EdgeKind1"]]}
        },
        {
          "name": "bounded variable-length one-hop",
          "vars": {
            "pattern": "(a:NodeKind1)-[:EdgeKind1*1..1]->(b:NodeKind2)",
            "predicate": "a.name = 'src'"
          },
          "assert": {"path_node_ids": [["a", "b"]], "path_edge_kinds": [["EdgeKind1"]]}
        }
      ]
    }
  ]
}
