{
  "families": [
    {
      "name": "typed path pattern materialization",
      "template": "match p={{pattern}} where {{predicate}} return p",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["TemplateNodeKind1"], "properties": {"name": "src"}},
          {"id": "b", "kinds": ["TemplateNodeKind2"], "properties": {"name": "mid"}},
          {"id": "c", "kinds": ["TemplateNodeKind1"], "properties": {"name": "dst"}},
          {"id": "d", "kinds": ["TemplateNodeKind2"], "properties": {"name": "inbound-src"}},
          {"id": "e", "kinds": ["TemplateNodeKind1"], "properties": {"name": "inbound"}}
        ],
        "edges": [
          {"start_id": "a", "end_id": "b", "kind": "TemplateEdgeKind1", "properties": {"label": "first"}},
          {"start_id": "b", "end_id": "c", "kind": "TemplateEdgeKind2", "properties": {"label": "second"}},
          {"start_id": "d", "end_id": "e", "kind": "TemplateEdgeKind1", "properties": {"label": "inbound"}}
        ]
      },
      "variants": [
        {
          "name": "directed typed one-hop",
          "vars": {
            "pattern": "(a:TemplateNodeKind1)-[:TemplateEdgeKind1]->(b:TemplateNodeKind2)",
            "predicate": "a.name = 'src'"
          },
          "assert": {"path_node_ids": [["a", "b"]], "path_edge_kinds": [["TemplateEdgeKind1"]]}
        },
        {
          "name": "undirected typed one-hop",
          "vars": {
            "pattern": "(a:TemplateNodeKind1)-[:TemplateEdgeKind1]-(b:TemplateNodeKind2)",
            "predicate": "a.name = 'src'"
          },
          "assert": {"path_node_ids": [["a", "b"]], "path_edge_kinds": [["TemplateEdgeKind1"]]}
        },
        {
          "name": "named relationship property filter",
          "vars": {
            "pattern": "(a:TemplateNodeKind1)-[r:TemplateEdgeKind1]->(b:TemplateNodeKind2)",
            "predicate": "a.name = 'src' and r.label = 'first'"
          },
          "assert": {"path_node_ids": [["a", "b"]], "contains_edge": {"start": "a", "end": "b", "kind": "TemplateEdgeKind1", "props": {"label": "first"}}}
        },
        {
          "name": "directed typed two-hop",
          "vars": {
            "pattern": "(a:TemplateNodeKind1)-[:TemplateEdgeKind1]->(b:TemplateNodeKind2)-[:TemplateEdgeKind2]->(c:TemplateNodeKind1)",
            "predicate": "a.name = 'src'"
          },
          "assert": {"path_node_ids": [["a", "b", "c"]], "path_edge_kinds": [["TemplateEdgeKind1", "TemplateEdgeKind2"]]}
        },
        {
          "name": "bounded variable-length two-hop",
          "vars": {
            "pattern": "(a:TemplateNodeKind1)-[:TemplateEdgeKind1|TemplateEdgeKind2*2..2]->(c:TemplateNodeKind1)",
            "predicate": "a.name = 'src'"
          },
          "assert": {"path_node_ids": [["a", "b", "c"]], "path_edge_kinds": [["TemplateEdgeKind1", "TemplateEdgeKind2"]]}
        },
        {
          "name": "inbound typed one-hop",
          "vars": {
            "pattern": "(e:TemplateNodeKind1)<-[:TemplateEdgeKind1]-(d:TemplateNodeKind2)",
            "predicate": "e.name = 'inbound'"
          },
          "assert": {"path_node_ids": [["e", "d"]], "path_edge_kinds": [["TemplateEdgeKind1"]]}
        },
        {
          "name": "bounded variable-length one-hop",
          "vars": {
            "pattern": "(a:TemplateNodeKind1)-[:TemplateEdgeKind1*1..1]->(b:TemplateNodeKind2)",
            "predicate": "a.name = 'src'"
          },
          "assert": {"path_node_ids": [["a", "b"]], "path_edge_kinds": [["TemplateEdgeKind1"]]}
        }
      ]
    },
    {
      "name": "path node-list functions",
      "template": "{{query}}",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["TemplateNodeKind1"], "properties": {"name": "src"}},
          {"id": "b", "kinds": ["TemplateNodeKind2"], "properties": {"name": "mid"}},
          {"id": "c", "kinds": ["TemplateNodeKind1"], "properties": {"name": "dst"}},
          {"id": "d", "kinds": ["TemplateNodeKind2"], "properties": {"name": "inbound-src"}},
          {"id": "e", "kinds": ["TemplateNodeKind1"], "properties": {"name": "inbound"}}
        ],
        "edges": [
          {"start_id": "a", "end_id": "b", "kind": "TemplateEdgeKind1", "properties": {"label": "first"}},
          {"start_id": "b", "end_id": "c", "kind": "TemplateEdgeKind2", "properties": {"label": "second"}},
          {"start_id": "d", "end_id": "e", "kind": "TemplateEdgeKind1", "properties": {"label": "inbound"}}
        ]
      },
      "variants": [
        {
          "name": "nodes function returns path traversal order",
          "vars": {
            "query": "match p=(a:TemplateNodeKind1)-[:TemplateEdgeKind1]->(b:TemplateNodeKind2)-[:TemplateEdgeKind2]->(c:TemplateNodeKind1) where a.name = 'src' return nodes(p)"
          },
          "assert": {"node_list_ids": [["a", "b", "c"]]}
        },
        {
          "name": "nodes function follows inbound path order",
          "vars": {
            "query": "match p=(e:TemplateNodeKind1)<-[:TemplateEdgeKind1]-(d:TemplateNodeKind2) where e.name = 'inbound' return nodes(p)"
          },
          "assert": {"node_list_ids": [["e", "d"]]}
        }
      ]
    },
    {
      "name": "shortest path relationship predicate functions",
      "template": "{{query}}",
      "fixture": {
        "nodes": [
          {"id": "src", "kinds": ["TemplateNodeKind1"], "properties": {"name": "path-filter-src"}},
          {"id": "blocked", "kinds": ["TemplateNodeKind2"], "properties": {"name": "blocked-session-host"}},
          {"id": "allowed", "kinds": ["TemplateNodeKind2"], "properties": {"name": "allowed-session-host"}},
          {"id": "long", "kinds": ["TemplateNodeKind2"], "properties": {"name": "longer-route"}},
          {"id": "dst", "kinds": ["TemplateNodeKind1"], "properties": {"name": "path-filter-dst"}}
        ],
        "edges": [
          {"start_id": "src", "end_id": "blocked", "kind": "TemplateEdgeKind1"},
          {"start_id": "blocked", "end_id": "dst", "kind": "HasSession"},
          {"start_id": "src", "end_id": "allowed", "kind": "TemplateEdgeKind1"},
          {"start_id": "allowed", "end_id": "long", "kind": "TemplateEdgeKind1"},
          {"start_id": "long", "end_id": "dst", "kind": "TemplateEdgeKind1"}
        ]
      },
      "variants": [
        {
          "name": "post-filtered shortest path is not replaced by longer path",
          "vars": {
            "query": "match p=shortestPath((s:TemplateNodeKind1)-[:TemplateEdgeKind1|HasSession*1..]->(d:TemplateNodeKind1)) where s.name = 'path-filter-src' and d.name = 'path-filter-dst' with p where none(r in relationships(p) where type(r) = 'HasSession' and startNode(r).name = 'blocked-session-host') return p"
          },
          "assert": "empty"
        },
        {
          "name": "path relationship type() supports string prefix predicates",
          "vars": {
            "query": "match p=(s:TemplateNodeKind1)-[:TemplateEdgeKind1|HasSession*1..1]->(n:TemplateNodeKind2) where s.name = 'path-filter-src' and n.name = 'blocked-session-host' and any(r in relationships(p) where type(r) STARTS WITH 'TemplateEdge') return p"
          },
          "assert": {"path_node_ids": [["src", "blocked"]], "path_edge_kinds": [["TemplateEdgeKind1"]]}
        }
      ]
    }
  ]
}
