{
  "metamorphic": [
    {
      "name": "fixed hop and bounded one-hop expansion return the same path",
      "compare": "path_node_ids",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["TemplateNodeKind1"], "properties": {"name": "src"}},
          {"id": "b", "kinds": ["TemplateNodeKind2"], "properties": {"name": "dst"}},
          {"id": "c", "kinds": ["TemplateNodeKind2"], "properties": {"name": "decoy"}}
        ],
        "edges": [
          {"start_id": "a", "end_id": "b", "kind": "TemplateEdgeKind1"},
          {"start_id": "a", "end_id": "c", "kind": "TemplateEdgeKind2"}
        ]
      },
      "queries": [
        {
          "name": "fixed one-hop",
          "cypher": "match p=(a:TemplateNodeKind1)-[:TemplateEdgeKind1]->(b:TemplateNodeKind2) where a.name = 'src' return p"
        },
        {
          "name": "bounded variable one-hop",
          "cypher": "match p=(a:TemplateNodeKind1)-[:TemplateEdgeKind1*1..1]->(b:TemplateNodeKind2) where a.name = 'src' return p"
        }
      ]
    },
    {
      "name": "shortest path agrees with the direct path when a longer branch exists",
      "compare": "path_node_ids",
      "fixture": {
        "nodes": [
          {"id": "s", "kinds": ["TemplateNodeKind1"], "properties": {"name": "src"}},
          {"id": "mid", "kinds": ["TemplateNodeKind1"], "properties": {"name": "mid"}},
          {"id": "e", "kinds": ["TemplateNodeKind2"], "properties": {"name": "dst"}}
        ],
        "edges": [
          {"start_id": "s", "end_id": "e", "kind": "TemplateEdgeKind1"},
          {"start_id": "s", "end_id": "mid", "kind": "TemplateEdgeKind1"},
          {"start_id": "mid", "end_id": "e", "kind": "TemplateEdgeKind1"}
        ]
      },
      "queries": [
        {
          "name": "direct path",
          "cypher": "match p=(s:TemplateNodeKind1)-[:TemplateEdgeKind1]->(e:TemplateNodeKind2) where s.name = 'src' and e.name = 'dst' return p"
        },
        {
          "name": "all shortest paths",
          "cypher": "match p=allShortestPaths((s:TemplateNodeKind1)-[*1..]->(e:TemplateNodeKind2)) where s.name = 'src' and e.name = 'dst' return p"
        }
      ]
    },
    {
      "name": "redundant null predicate preserves the matched node set",
      "compare": "node_ids",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["TemplateNodeKind1"], "properties": {"name": "target"}},
          {"id": "b", "kinds": ["TemplateNodeKind1"], "properties": {"name": "other"}},
          {"id": "c", "kinds": ["TemplateNodeKind1"], "properties": {"enabled": true}}
        ],
        "edges": []
      },
      "queries": [
        {
          "name": "base predicate",
          "cypher": "match (n:TemplateNodeKind1) where n.name = 'target' return n"
        },
        {
          "name": "redundant null check",
          "cypher": "match (n:TemplateNodeKind1) where n.name = 'target' and n.name is not null return n"
        }
      ]
    },
    {
      "name": "WITH carry-through preserves ordered scalar projections",
      "compare": "ordered_scalar_values",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["TemplateNodeKind1"], "properties": {"name": "beta", "tag": "ordered"}},
          {"id": "b", "kinds": ["TemplateNodeKind1"], "properties": {"name": "alpha", "tag": "ordered"}},
          {"id": "c", "kinds": ["TemplateNodeKind2"], "properties": {"name": "gamma", "tag": "ordered"}}
        ],
        "edges": []
      },
      "queries": [
        {
          "name": "direct ordered projection",
          "cypher": "match (n:TemplateNodeKind1) where n.tag = 'ordered' return n.name order by n.name"
        },
        {
          "name": "ordered projection through WITH",
          "cypher": "match (n:TemplateNodeKind1) where n.tag = 'ordered' with n return n.name order by n.name"
        }
      ]
    },
    {
      "name": "DISTINCT preserves the reachable source node set",
      "compare": "node_id_set",
      "fixture": {
        "nodes": [
          {"id": "src", "kinds": ["TemplateNodeKind1"], "properties": {"name": "source"}},
          {"id": "a", "kinds": ["TemplateNodeKind2"]},
          {"id": "b", "kinds": ["TemplateNodeKind2"]}
        ],
        "edges": [
          {"start_id": "src", "end_id": "a", "kind": "TemplateEdgeKind1"},
          {"start_id": "src", "end_id": "b", "kind": "TemplateEdgeKind1"}
        ]
      },
      "queries": [
        {
          "name": "duplicated traversal source rows",
          "cypher": "match (n:TemplateNodeKind1)-[:TemplateEdgeKind1]->() where n.name = 'source' return n"
        },
        {
          "name": "distinct traversal source rows",
          "cypher": "match (n:TemplateNodeKind1)-[:TemplateEdgeKind1]->() where n.name = 'source' return distinct n"
        }
      ]
    }
  ]
}
