          {"start_id": "root", "end_id": "domain", "kind": "RootCAFor"}
        ]
      },
      "assert": {
        "row_count": 4,
        "path_node_ids": [
          ["n", "p1-a", "ca", "store", "domain"],
          ["n", "p1-a", "ca", "store", "domain"],
          ["n", "p1-b", "ca", "store", "domain"],
          ["n", "p1-b", "ca", "store", "domain"],
          ["n", "p2-a", "template-a", "ca", "root", "domain"],
          ["n", "p2-a", "template-a", "ca", "root", "domain"],
          ["n", "p2-b", "template-b", "ca", "root", "domain"],
          ["n", "p2-b", "template-b", "ca", "root", "domain"]
        ],
        "path_edge_kinds": [
          ["MemberOf", "Enroll", "TrustedForNTAuth", "NTAuthStoreFor"],
          ["MemberOf", "Enroll", "TrustedForNTAuth", "NTAuthStoreFor"],
          ["MemberOf", "Enroll", "TrustedForNTAuth", "NTAuthStoreFor"],
          ["MemberOf", "Enroll", "TrustedForNTAuth", "NTAuthStoreFor"],
          ["MemberOf", "GenericAll", "PublishedTo", "IssuedSignedBy", "RootCAFor"],
          ["MemberOf", "GenericAll", "PublishedTo", "IssuedSignedBy", "RootCAFor"],
          ["MemberOf", "AllExtendedRights", "PublishedTo", "IssuedSignedBy", "RootCAFor"],
          ["MemberOf", "AllExtendedRights", "PublishedTo", "IssuedSignedBy", "RootCAFor"]
