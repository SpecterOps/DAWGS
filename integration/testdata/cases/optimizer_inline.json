          ["n", "mid-sig", "template-sig", "ca", "root", "domain"]
        ],
        "path_edge_kinds": [
          ["MemberOf", "GenericAll", "PublishedTo", "IssuedSignedBy", "RootCAFor"],
          ["MemberOf", "Enroll", "PublishedTo", "IssuedSignedBy", "RootCAFor"]
        ]
      }
    },
    {
