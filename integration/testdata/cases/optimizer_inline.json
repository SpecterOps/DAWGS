          {"id": "user", "kinds": ["User"]},
          {"id": "computer", "kinds": ["Computer"]},
          {"id": "mid", "kinds": ["Group"]},
          {"id": "other", "kinds": ["Group"], "properties": {"objectid": "S-1-5-21-1-513"}},
          {"id": "ignored", "kinds": ["Base"]}
        ],
        "edges": [
          {"start_id": "user", "end_id": "admins", "kind": "MemberOf"},
          {"start_id": "computer", "end_id": "mid", "kind": "MemberOf"},
