{
  "cases": [
    {
      "name": "group nodes by a property and return the sum of another property per group",
      "cypher": "MATCH (n) RETURN n.department, sum(n.salary)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"department": "eng", "salary": 100}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {"department": "eng", "salary": 200}},
          {"id": "c", "kinds": ["NodeKind2"], "properties": {"department": "hr", "salary": 150}}
        ],
        "edges": []
      },
      "assert": "non_empty"
    },
    {
      "name": "group nodes by a property and return the average of another property per group",
      "cypher": "MATCH (n) RETURN n.department, avg(n.age)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"department": "eng", "age": 30}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {"department": "eng", "age": 40}}
        ],
        "edges": []
      },
      "assert": "non_empty"
    },
    {
      "name": "compute count sum avg min and max of a property in a single projection",
      "cypher": "MATCH (n) RETURN count(n), sum(n.age), avg(n.age), min(n.age), max(n.age)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"age": 25}},
          {"id": "b", "kinds": ["NodeKind2"], "properties": {"age": 35}}
        ],
        "edges": []
      },
      "assert": "non_empty"
    },
    {
      "name": "max string property remains textual",
      "cypher": "MATCH (n) RETURN max(n.name)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"name": "ALICE"}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {"name": "BOB"}}
        ],
        "edges": []
      },
      "assert": {"scalar_values": ["BOB"]}
    },
    {
      "name": "max string property with literals and count",
      "cypher": "MATCH (n) WHERE n.name = 'ALICE' RETURN 7 - 6 = 1, count(n), max(n.name)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"name": "ALICE"}}
        ],
        "edges": []
      },
      "assert": {"row_values": [[true, 1, "ALICE"]]}
    },
    {
      "name": "min and max string properties remain textual",
      "cypher": "MATCH (n) RETURN min(n.name), max(n.name)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"name": "ALICE"}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {"name": "BOB"}}
        ],
        "edges": []
      },
      "assert": {"row_values": [["ALICE", "BOB"]]}
    },
    {
      "name": "min and max numeric properties preserve numeric ordering",
      "cypher": "MATCH (n) RETURN min(n.score), max(n.score)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"score": 2}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {"score": 10}}
        ],
        "edges": []
      },
      "assert": {"row_values": [[2, 10]]}
    },
    {
      "name": "min and max mixed property values use cypher type ordering",
      "cypher": "MATCH (n) RETURN min(n.value), max(n.value)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"value": 1}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {"value": "99"}},
          {"id": "c", "kinds": ["NodeKind1"], "properties": {"value": 0.2}},
          {"id": "d", "kinds": ["NodeKind1"], "properties": {"value": "1"}},
          {"id": "e", "kinds": ["NodeKind1"], "properties": {"value": [1, 2]}}
        ],
        "edges": []
      },
      "assert": {"row_values": [[[1, 2], 1]]}
    },
    {
      "name": "min and max ignore null and missing property values",
      "cypher": "MATCH (n) RETURN min(n.value), max(n.value)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"value": null}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {}},
          {"id": "c", "kinds": ["NodeKind1"], "properties": {"value": 4}}
        ],
        "edges": []
      },
      "assert": {"row_values": [[4, 4]]}
    },
    {
      "name": "group nodes by a property and collect names per group",
      "cypher": "MATCH (n) RETURN n.department, collect(n.name)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"department": "eng", "name": "alice"}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {"department": "eng", "name": "bob"}}
        ],
        "edges": []
      },
      "assert": "non_empty"
    },
    {
      "name": "group nodes by a property and return both a collected list and a count",
      "cypher": "MATCH (n) RETURN n.department, collect(n.name), count(n)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"department": "ops", "name": "carol"}},
          {"id": "b", "kinds": ["NodeKind2"], "properties": {"department": "ops", "name": "dave"}}
        ],
        "edges": []
      },
      "assert": "non_empty"
    },
    {
      "name": "compute a ratio by dividing two aggregate results in a WITH stage",
      "cypher": "MATCH (n) WITH sum(n.age) as total_age, count(n) as total_count RETURN total_age / total_count as avg_age",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"age": 30}},
          {"id": "b", "kinds": ["NodeKind2"], "properties": {"age": 50}}
        ],
        "edges": []
      },
      "assert": "non_empty"
    },
    {
      "name": "count distinct property values from typed nodes",
      "cypher": "MATCH (n:NodeKind1) RETURN count(distinct n.department)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"department": "eng"}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {"department": "eng"}},
          {"id": "c", "kinds": ["NodeKind1"], "properties": {"department": "ops"}}
        ],
        "edges": []
      },
      "assert": {"exact_int": 2}
    },
    {
      "name": "add two aggregate counts inside one projection",
      "cypher": "MATCH (n) RETURN count(n) + count(n)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {}}
        ],
        "edges": []
      },
      "assert": {"exact_int": 4}
    },
    {
      "name": "multiply an aggregate count by a literal inside one projection",
      "cypher": "MATCH (n) RETURN count(n) * 2",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {}},
          {"id": "c", "kinds": ["NodeKind1"], "properties": {}}
        ],
        "edges": []
      },
      "assert": {"exact_int": 6}
    },
    {
      "name": "order by aliased aggregate projection",
      "cypher": "MATCH (n) RETURN count(n) AS total ORDER BY total DESC",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {}}
        ],
        "edges": []
      },
      "assert": {
        "keys": ["total"],
        "ordered_row_values": [[2]]
      }
    },
    {
      "name": "add grouped property expression to aggregate count inline",
      "cypher": "MATCH (n) RETURN toint(n.value) + count(n)",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"value": 10}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {"value": 10}},
          {"id": "c", "kinds": ["NodeKind1"], "properties": {"value": 20}}
        ],
        "edges": []
      },
      "assert": {"scalar_values": [12, 21]}
    },
    {
      "name": "add grouped property expression to aggregate count through aliases",
      "cypher": "MATCH (n) WITH toInteger(n.value) AS value, count(n) AS node_count RETURN value + node_count",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"value": 10}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {"value": 10}},
          {"id": "c", "kinds": ["NodeKind1"], "properties": {"value": 20}}
        ],
        "edges": []
      },
      "assert": {"scalar_values": [12, 21]}
    },
    {
      "name": "project grouped property plus aggregate through with inline expression",
      "cypher": "MATCH (n) WITH toint(n.value) + count(n) AS score RETURN score",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"value": 10}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {"value": 10}},
          {"id": "c", "kinds": ["NodeKind1"], "properties": {"value": 20}}
        ],
        "edges": []
      },
      "assert": {"scalar_values": [12, 21]}
    },
    {
      "name": "project grouped property plus aggregate through with aliases",
      "cypher": "MATCH (n) WITH toInteger(n.value) AS value, count(n) AS node_count WITH value + node_count AS score RETURN score",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"value": 10}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {"value": 10}},
          {"id": "c", "kinds": ["NodeKind1"], "properties": {"value": 20}}
        ],
        "edges": []
      },
      "assert": {"scalar_values": [12, 21]}
    },
    {
      "name": "compare aggregate count inside with projection",
      "cypher": "MATCH (n) WITH count(n) > 1 AS many RETURN many",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {}}
        ],
        "edges": []
      },
      "assert": {"scalar_values": [true]}
    },
    {
      "name": "divide aggregate sum by aggregate count inside with projection",
      "cypher": "MATCH (n) WITH sum(n.age) / count(n) AS avg_age RETURN avg_age",
      "fixture": {
        "nodes": [
          {"id": "a", "kinds": ["NodeKind1"], "properties": {"age": 30}},
          {"id": "b", "kinds": ["NodeKind1"], "properties": {"age": 50}}
        ],
        "edges": []
      },
      "assert": {"scalar_values": [40]}
    }
  ]
}
